  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "홍길동"
          },
          "email": {
            "type": "string",
            "example": "user@univ.ac.kr"
          },
          "phone": {
            "type": "string",
            "example": "01012345678"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "PROFESSOR",
              "STUDENT"
            ],
            "example": "STUDENT"
          }
        },
        "required": [
          "name",
          "email",
          "phone",
          "role"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "홍길동"
          },
          "email": {
            "type": "string",
            "example": "user@univ.ac.kr"
          },
          "phone": {
            "type": "string",
            "example": "01012345678"
          }
        }
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "idNumber": {
            "type": "string",
            "example": "20260000"
          },
          "password": {
            "type": "string",
            "example": "secret1234"
          }
        },
        "required": [
          "idNumber",
          "password"
        ]
      },
      "AdminLoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@univ.ac.kr"
          },
          "password": {
            "type": "string",
            "example": "admin1234"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateCourseDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "courseType": {
            "type": "string"
          },
          "credits": {
            "type": "number"
          },
          "capacity": {
            "type": "number"
          },
          "timeTables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "title",
          "courseType",
          "credits",
          "capacity",
          "timeTables"
        ]
      },
      "UpdateCourseDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          }
        }
      },
      "CreateEnrollmentDto": {
        "type": "object",
        "properties": {
          "courseId": {
            "type": "number",
            "example": 1
          }
        },
        "required": [
          "courseId"
        ]
      },
      "UpdatePasswordDto": {
        "type": "object",
        "properties": {
          "newPassword": {
            "type": "string",
            "example": "secret1234",
            "description": "10글자 이상"
          },
          "currentPassword": {
            "type": "string",
            "example": "0000",
            "description": "초기 비밀번호는 0000입니다."
          }
        },
        "required": [
          "newPassword",
          "currentPassword"
        ]
      }
    }
  }
